# LawFront — Environment Variables Reference
# ───────────────────────────────────────────
# Copy to .env (development) or .env.production (production) and fill in values.
# For CI/CD, set these as GitHub Actions secrets / environment variables.

# Laravel Backend URL (no trailing slash)
# Dev:  http://localhost:8000 or http://127.0.0.1:8000/api
# Prod: https://chambersapi.logicera.in
REACT_APP_API_URL=

# Kuberdhan Wallet Microservice URL (no trailing slash)
# Dev:  http://localhost:8001
# Prod: https://your-kuberdhan-service.run.app (or Railway / EC2 URL)
REACT_APP_KUBERDHAN_API_URL=

# Google OAuth Client ID
REACT_APP_GOOGLE_CLIENT_ID=

# Chatbot API URL
REACT_APP_CHATBOT_API_URL=
